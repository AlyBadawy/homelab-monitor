{
  "name": "homelab-monitor-backend",
  "version": "0.13.1",
  "private": true,
  "description": "Homelab monitor backend — polls services, stores 24h history in SQLite, serves a REST API.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "ssh2": "^1.17.0",
    "undici": "^6.20.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "@types/ssh2": "^1.15.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
