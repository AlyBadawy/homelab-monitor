# Reference list of env vars consumed by docker-compose.yml.
# When deploying via Portainer, paste these as "Environment variables" on the
# stack creation screen — do NOT commit the real values to git.

# ----- Proxmox -----
# Full token in the form user@realm!tokenname
PROXMOX_TOKEN_ID=monitor@pve!dashboard
# UUID-like secret shown once when the token was created
PROXMOX_TOKEN_SECRET=CHANGE_ME
# Optional: override the Proxmox URL. Defaults to https://proxmox.in.alybadawy.com.
# Set to https://<proxmox-ip>:8006 and flip PROXMOX_INSECURE_TLS=true if NPM is unreachable.
PROXMOX_BASE_URL=https://proxmox.in.alybadawy.com
# Skip TLS verification (needed only when talking to PVE's self-signed cert directly)
PROXMOX_INSECURE_TLS=false

# ----- Frontend -----
# Host port that maps to the frontend container's :80
FRONTEND_PORT=8080
